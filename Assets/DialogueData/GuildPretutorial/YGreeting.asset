  m_Script: {fileID: 11500000, guid: 84736f00ca5690940aa2333ea4ce800b, type: 3}
  m_Name: YGreeting
  m_EditorClassIdentifier: 
  dialogue:
  - "Hey bro! Check out my setup, pretty nifty eh? \nBadgered the upper suits enough
    to get allowance to recreate my workshop over here."
  - "Hows seeing it all first hand? Hoping its living up to \nwhat you imagined.
    Let me know if you need anything alright?"
  - "I'm right here if anything starts getting overwhelming. \nYou've got someone
    on the inside in your corner, \nliterally! Use that to your advantage."
  responses:
  - unPauser: 0
    responseText: I'm fine!!
    dialogueObject: {fileID: 11400000, guid: e56f1c6e099c5af4eb919b615a882c78, type: 2}
  - unPauser: 0
    responseText: You got it!
    dialogueObject: {fileID: 11400000, guid: 2b9986ee7da65314b9551bdec687cecb, type: 2}
  interactable: 1
  unPause: 0
  hold: 0
